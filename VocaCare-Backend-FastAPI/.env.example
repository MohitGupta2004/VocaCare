# VocaCare Backend — Environment Variables
# Copy this to .env and fill in your values

# ── MongoDB ────────────────────────────────────────────────────────────────
# Local MongoDB (default — no setup needed if MongoDB is installed)
MONGO_URI=mongodb://localhost:27017

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
