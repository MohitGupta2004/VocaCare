# VocaCare Backend — Local Environment
# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=vocare-super-secret-key-change-before-production
JWT_EXPIRE_HOURS=8

# ── Default Admin (seeded on first startup) ────────────────────────────────
ADMIN_EMAIL=admin@vocare.com
ADMIN_PASSWORD=Admin@VocaCare123
ADMIN_FULL_NAME=System Administrator

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
